BENCHMARKS="BenchmarkStartRequestSpan|BenchmarkHttpServeTrace|BenchmarkTracerAddSpans"
CPUS_PER_BENCHMARK=1
REPETITIONS=1
GROUP_ID="group-1"

# Branch to use during local run
CI_COMMIT_REF_NAME=main

# A commit to use during local run, specifying a branch name will checkout the latest commit from that branch
CI_COMMIT_SHA=main
